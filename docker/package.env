# 打包基础信息；可以在执行脚本前用同名环境变量覆盖。
: "${APP_ID:=hcly-behavior-desktop}"
: "${APP_DISPLAY_NAME:=留置中心打标}"
if [[ -z "${APP_VERSION:-}" ]]; then
    if [[ -n "${PROJECT_ROOT:-}" ]]; then
        PACKAGE_PROJECT_ROOT="${PROJECT_ROOT}"
    else
        PACKAGE_ENV_PATH="${BASH_SOURCE[0]:-$0}"
        PACKAGE_PROJECT_ROOT="$(cd "$(dirname "${PACKAGE_ENV_PATH}")/.." && pwd)"
    fi
    if [[ -n "${PYTHON_BIN:-}" ]]; then
        PACKAGE_PYTHON_BIN="${PYTHON_BIN}"
    elif command -v python3 >/dev/null 2>&1; then
        PACKAGE_PYTHON_BIN="python3"
    elif command -v python >/dev/null 2>&1; then
        PACKAGE_PYTHON_BIN="python"
    else
        printf '错误: 未找到 python3 或 python，无法读取应用版本号\n' >&2
        exit 1
    fi
    APP_VERSION="$(
        "${PACKAGE_PYTHON_BIN}" - "${PACKAGE_PROJECT_ROOT}/src/config/settings.py" <<'PY'
import ast
import sys
from pathlib import Path

values = {}
settings_path = Path(sys.argv[1])
module = ast.parse(settings_path.read_text(encoding="utf-8"))
for node in module.body:
    if not isinstance(node, ast.Assign) or len(node.targets) != 1:
        continue
    target = node.targets[0]
    if not isinstance(target, ast.Name):
        continue
    try:
        values[target.id] = ast.literal_eval(node.value)
    except (ValueError, SyntaxError):
        if isinstance(node.value, ast.Name):
            values[target.id] = values.get(node.value.id, "")

print(values.get("APP_VERSION") or values.get("APP_VERSION_NAME") or "1.0.0")
PY
    )"
fi
unset PACKAGE_PROJECT_ROOT PACKAGE_ENV_PATH PACKAGE_PYTHON_BIN
: "${APP_VERSION:=1.0.0}"
: "${APP_MAINTAINER:=Hcly <support@example.local>}"
: "${DOCKER_IMAGE:=hcly-behavior-desktop-packager:py311-bullseye}"
: "${DOCKER_PLATFORM:=linux/amd64}"

# 默认不携带 Qt/X11 等系统库，优先减小 deb 体积；目标机缺库时再设为 1。
: "${BUNDLE_SYSTEM_LIBS:=0}"

# 默认携带 glibc，兼容国产机上常见的旧 glibc；要极限瘦身且确认目标机 glibc 足够新时可设为 0。
: "${BUNDLE_GLIBC:=1}"

# fcitx5 Qt6 插件是中文输入增强项；默认不因插件缺失或二进制不兼容中断打包。
: "${REQUIRE_FCITX_PLUGIN:=0}"

# 默认只保留 X11/xcb 平台插件来瘦身；需要 Wayland 时执行前设置 KEEP_WAYLAND=1。
: "${KEEP_WAYLAND:=0}"

# 默认移除当前项目未用到的 Qt QML 模块；排查兼容问题时可设置 KEEP_EXTRA_QML=1。
: "${KEEP_EXTRA_QML:=0}"

# UPX 能继续压缩体积，但 Qt 动态库偶尔会不兼容；需要时执行前设置 ENABLE_UPX=1。
: "${ENABLE_UPX:=0}"
